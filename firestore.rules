rules_version = '2';

// ============================================================================
// FIRESTORE SECURITY RULES
// Paste these into Firebase Console → Firestore Database → Rules → Publish
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Username lookups (read-only, any signed-in user) ───────────────
    match /usernames/{username} {
      allow read: if request.auth != null;
      // Only allow create on signup (no update/delete from clients)
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
    }

    // ─── User profiles ──────────────────────────────────────────────────
    match /users/{userId} {
      // Anyone signed in can read profiles (for leaderboards, profiles, etc.)
      allow read: if request.auth != null;

      // Only the user can create their own document
      allow create: if request.auth != null && request.auth.uid == userId;

      // The user can update their own profile, OR another user can perform
      // limited social actions (friend requests, friends list, blocks).
      allow update: if request.auth != null && (
        // Self updates: any field allowed
        request.auth.uid == userId
        // OR another user is sending a friend request (only writing to friendRequests)
        || onlyChangingFields(['friendRequests', 'friends', 'blocked'])
      );

      allow delete: if false; // never delete from client
    }

    // ─── Invites ────────────────────────────────────────────────────────
    match /invites/{inviteId} {
      // Read: only sender or recipient
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.fromId
        || request.auth.uid == resource.data.toId
      );
      // Create: sender must match
      allow create: if request.auth != null
                    && request.resource.data.fromId == request.auth.uid;
      // Update: sender or recipient (for accept/decline/cancel)
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.fromId
        || request.auth.uid == resource.data.toId
      );
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.fromId;
    }

    // ─── Matches ────────────────────────────────────────────────────────
    match /matches/{matchId} {
      // Read: anyone signed in (so spectators can watch)
      allow read: if request.auth != null;
      // Create: must be one of the players
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.players;
      // Update: players can update game state, anyone signed in can update
      // spectators/chat (we trust the client here since we keep it simple)
      allow update: if request.auth != null;
      allow delete: if false;
    }
  }
}

// Helper: did the request only change the listed fields?
function onlyChangingFields(allowedFields) {
  return request.auth != null
      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedFields);
}
